# Supabase progressive enhancement (OPTIONAL — the app is fully functional
# without these; it boots from the static files in public/ regardless).
# Set both to enable: dataset hydration when the database is newer, source
# titles in the panel, and the per-country Policy Initiatives section.
#
# The anon key is safe to expose in the frontend bundle: Row Level Security
# admits SELECT only. Never put the service_role key here.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-or-publishable-key>
